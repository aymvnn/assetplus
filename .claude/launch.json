{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "interfleet-site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/index.html':decodeURIComponent(q.url),f=p.join(process.cwd(),u),e=p.extname(f),m={'.html':'text/html','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.svg':'image/svg+xml','.webp':'image/webp','.ico':'image/x-icon','.mp4':'video/mp4','.webm':'video/webm','.webp':'image/webp','.gif':'image/gif','.ttf':'font/ttf','.woff':'font/woff','.woff2':'font/woff2'};fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':m[e]||'application/octet-stream'});r.end(d)}})}).listen(8080,()=>console.log('Serving on http://localhost:8080'))"],
      "port": 8080
    }
  ]
}